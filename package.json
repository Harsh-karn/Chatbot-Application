{
  "name": "llm-inference-logging-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "sdk",
    "backend",
    "frontend"
  ],
  "scripts": {
    "bootstrap": "npm install",
    "dev:backend": "npm --workspace=backend run dev",
    "dev:frontend": "npm --workspace=frontend run dev",
    "dev": "npm run dev:backend",
    "build:sdk": "npm --workspace=sdk run build",
    "build:backend": "npm --workspace=backend run build",
    "build:frontend": "npm --workspace=frontend run build",
    "build": "npm run build:sdk && npm run build:backend && npm run build:frontend"
  }
}
