# Server Configurations
PORT=5000
NODE_ENV=development

# Database Configurations
# Use SQLite by default for host-based zero-dependency run:
DATABASE_URL="file:./dev.db"
# Use PostgreSQL inside Docker Compose or production:
# DATABASE_URL="postgresql://postgres:postgres_password@localhost:5432/inference_logger?schema=public"

# Redis Configuration (Optional for host run, required for Docker event-driven logging)
# REDIS_URL="redis://localhost:6379"

# LLM API Keys (Google Gemini is supported natively. Others are simulated if keys are missing)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
OPENAI_API_KEY="YOUR_OPENAI_API_KEY_OPTIONAL"
ANTHROPIC_API_KEY="YOUR_ANTHROPIC_API_KEY_OPTIONAL"
